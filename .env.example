# ─── Agent Bunker Configuration ───────────────────────────────────────────────
# Copy this file to .env and customize for your setup.
# All paths should be absolute. The server reads these at startup.

# ─── Core Paths ──────────────────────────────────────────────────────────────
# Root workspace directory where your agent stores memory, configs, etc.
WORKSPACE_ROOT=./data/workspace

# Path to your cron/scheduled jobs JSON file
CRON_JOBS_FILE=./data/cron/jobs.json

# Path to your activity log JSON file
ACTIVITY_FILE=./data/activity.json

# ─── Agent Data Paths (for Agents Playground tab) ────────────────────────────
# Path to subagent execution history
SUBAGENT_RUNS_FILE=./data/subagents/runs.json

# Path to agent chat sessions
SESSIONS_FILE=./data/sessions/sessions.json

# Path to agent progress tracking
PROGRESS_FILE=./data/progress.json

# Directory containing agent log files
LOGS_DIR=./data/logs

# ─── Skills ──────────────────────────────────────────────────────────────────
# Comma-separated directories to scan for skills (SKILL.md files)
SKILL_DIRS=./data/skills

# ─── Usage Monitoring ────────────────────────────────────────────────────────
# Path to a script that outputs JSON usage data (session + weekly windows)
# Leave empty to disable the usage tab
USAGE_SCRIPT=

# ─── Moltbook Integration (Optional) ────────────────────────────────────────
# API token for Moltbook social platform integration
# Leave empty to disable Moltbook tab
MOLTBOOK_API_TOKEN=
# Your agent's username on Moltbook
MOLTBOOK_AGENT_NAME=

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001

# ─── MCP Explorer (Optional) ─────────────────────────────────────────────────
# Path to an awesome-mcp-servers README.md file for the MCP Explorer tab
# Clone https://github.com/punkpeye/awesome-mcp-servers and point here
# Leave empty to disable the MCP Explorer tab
MCP_README=

# ─── Branding ────────────────────────────────────────────────────────────────
# Customize the dashboard name (shown in sidebar header)
APP_NAME=Agent Bunker
